# API Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Browser-side API base path.  In production the Next.js server proxies
# /api/* to the Express backend via next.config.js rewrites, so this should
# remain /api.  Override only if you bypass the Next.js proxy entirely.
NEXT_PUBLIC_API_URL=/api
# Server-side destination for the Next.js /api proxy (not exposed to browser).
# In production set this to your backend's public HTTPS URL, e.g.
# https://my-backend.railway.app
# IMPORTANT: Always use https:// in production.  Using http:// will cause
# Railway (and most PaaS hosts) to issue a 301 HTTP→HTTPS redirect, which
# converts POST requests to GET and breaks the login flow.
BACKEND_URL=http://localhost:4000

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Feature Flags
NEXT_PUBLIC_ENABLE_REGISTRATION=true

# Internal System Access Protection
# A strong, random secret that must be included as ?access=<token> in the URL
# when an unauthenticated user wants to reach the admin or super-admin login page.
# Unauthenticated requests to /admin/* or /super-admin/* without this token return 404,
# making the internal system invisible to the public.
#
# Usage (share only with authorised staff):
#   https://<your-domain>/admin/login?access=<ADMIN_ACCESS_TOKEN>
#   https://<your-domain>/super-admin/login?access=<ADMIN_ACCESS_TOKEN>
#
# Generate a strong value with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave blank to disable the gate (useful for local development / initial setup).
ADMIN_ACCESS_TOKEN=