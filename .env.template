# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_at_least_32_characters

# Frontend API URL
# Browser-side API base path (proxied through Next.js rewrites to BACKEND_URL).
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Backend URL used by the Next.js server to proxy /api/* requests.
# In production (e.g. Railway) set this to the Express backend's public HTTPS URL.
# IMPORTANT: Always use https:// in production.  Using http:// will cause
# Railway (and most PaaS hosts) to issue a 301 HTTP→HTTPS redirect, which
# converts POST requests to GET and breaks the login flow.
BACKEND_URL=http://localhost:4000

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Institute Configuration
NEXT_PUBLIC_INSTITUTE_NAME=EdTech Institute
NEXT_PUBLIC_INSTITUTE_TAGLINE=Empowering Education

# Environment
NODE_ENV=development

# Payment HMAC Secret (for cryptographic receipts)
# Generate a strong secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
PAYMENT_HMAC_SECRET=your_payment_hmac_secret_at_least_32_characters