# Server Configuration
NODE_ENV=development
PORT=4000

# Database (Supabase)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis Configuration (for job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS — must match the deployed frontend origin exactly)
# In production use the HTTPS URL, e.g. https://my-frontend.railway.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Email Configuration (optional)
EMAIL_FROM=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_NOTIFICATIONS=false

# Backblaze B2 (S3-compatible) — used for course materials, gallery images, and general file uploads.
# Profile photos / avatars remain in Supabase Storage.
# Never expose these values to the frontend (no NEXT_PUBLIC_B2_* variables).
B2_KEY_ID=your_backblaze_key_id
B2_APP_KEY=your_backblaze_application_key
B2_BUCKET=your_bucket_name
B2_ENDPOINT=https://s3.us-west-001.backblazeb2.com